# ============================================================
# INBOX INTELLIGENCE AGENT — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual keys:
#   copy .env.example .env
# ============================================================

# ---------- LLM API Key (Required) ----------
# Get your free Gemini API key from: https://aistudio.google.com/
GOOGLE_API_KEY=paste-your-gemini-api-key-here

# ---------- Multi-Agent Rate Limit Failovers (LiteLLM) ----------
# To prevent Rate Limits when running locally during the hackathon,
# the framework will automatically pull ANY key starting with these prefixes
# and load-balance across them using the new Router logic.
GEMINI_API_KEY_1=paste-your-custom-gemini-key-1
# GEMINI_API_KEY_2=paste-another-gemini-key-to-double-rpm
GROQ_API_KEY_1=paste-your-groq-key-here
GITHUB_API_KEY_1=paste-your-github-models-token-here

# ---------- LangSmith (Optional — for visual agent tracing) ----------
# Sign up free at: https://smith.langchain.com/
# Uncomment the lines below after getting your key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=paste-your-langsmith-key-here
# LANGCHAIN_PROJECT=inbox-intelligence-agent
